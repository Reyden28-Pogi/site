# Supabase (shared project for all tenants). Also used automatically by
# the frontend to build public image URLs — no separate image-host env
# var needed, since images are stored in Supabase Storage (see README
# section 4).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Which business (tenant) this deployment serves on the public site.
# Must match a `slug` value in the `businesses` table.
# Leave BLANK (or unset) for the Super Admin control deployment.
VITE_BUSINESS_SLUG=

# Cloudflare Turnstile (captcha) — site key is public/non-secret, used by
# the frontend to render the widget. The matching secret key lives only in
# the submit-lead Edge Function's secrets (see README section 3.5).
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Used by the submit-lead Edge Function
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Used by the send-lead-notification Edge Function
RESEND_API_KEY=your-resend-or-smtp-provider-key
NOTIFICATION_FROM_EMAIL=notifications@yourdomain.com
# Shared secret this function requires on incoming requests (set the same
# value as a custom header on the Supabase Database Webhook that calls it —
# see README section 3.4). Without this, the function would be a public,
# unauthenticated endpoint.
LEAD_WEBHOOK_SECRET=generate-a-long-random-value
